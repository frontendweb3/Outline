<section class="border-t border-border">
    <div class="max-w-7xl mx-auto px-4 md:px-8 py-16 md:py-20 text-center">
        <h2 class="text-2xl md:text-3xl font-extrabold tracking-tight mb-3">Join the Frontend.fyi newsletter.</h2>
        <p class="text-muted-foreground max-w-xl mx-auto mb-8 leading-relaxed">
            Stay up to date about new content releases, both free and paid. We won't spam you.
        </p>
        <form class="flex flex-col sm:flex-row items-center justify-center gap-3 max-w-md mx-auto" data-members-form="subscribe">
            <input
                class="w-full sm:flex-1 px-4 py-2.5 rounded-lg bg-muted border border-input text-foreground placeholder:text-muted-foreground text-sm focus:outline-none focus:ring-2 focus:ring-ring"
                type="email"
                placeholder="you@example.com"
                required
                data-members-email
            />
            <button
                class="w-full sm:w-auto px-5 py-2.5 rounded-lg bg-foreground text-background text-sm font-semibold hover:opacity-90 transition-opacity"
                type="submit"
            >
                Subscribe
            </button>
        </form>
    </div>
</section>

<footer class="py-10 border-t border-border">
    <div class="max-w-7xl mx-auto px-4 md:px-8">
        <div class="flex flex-col md:flex-row justify-between items-center gap-6">
            <div class="text-sm text-muted-foreground">
                &copy; {{date format="YYYY"}} {{@site.title}}. All rights reserved.
            </div>
            <div class="flex items-center gap-6">
                {{navigation type="secondary"}}
            </div>
            <div class="flex items-center gap-4">
                {{#if @site.facebook}}
                    <a href="{{social_url type="facebook"}}" class="text-muted-foreground hover:text-foreground transition-colors" aria-label="Facebook" target="_blank" rel="noopener">
                        <span class="size-5 block">{{> "icons/facebook"}}</span>
                    </a>
                {{/if}}
                {{#if @site.twitter}}
                    <a href="{{social_url type="twitter"}}" class="text-muted-foreground hover:text-foreground transition-colors" aria-label="Twitter" target="_blank" rel="noopener">
                        <span class="size-5 block">{{> "icons/x"}}</span>
                    </a>
                {{/if}}
                <a href="https://www.youtube.com/@frontendfyi" class="text-muted-foreground hover:text-foreground transition-colors" aria-label="YouTube" target="_blank" rel="noopener">
                    <span class="size-5 block">{{> "icons/youtube"}}</span>
                </a>
                {{#> "components/button" href="https://www.github.com/frontendfyi" variant="ghost" size="icon" ariaLabel="GitHub" target="_blank"}}
                    {{> "components/icon" name="github" ariaLabel="GitHub"}}
                {{/ "components/button"}}
            </div>
        </div>
    </div>
</footer>
