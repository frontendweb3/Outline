<footer class="border-t border-border py-10">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
        <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
            <div class="text-sm font-medium text-muted-foreground">
                &copy; {{date format="YYYY"}} {{@site.title}}. All rights reserved.
            </div>
            <div class="flex items-center gap-6">
                {{navigation type="secondary"}}
            </div>
            <div class="flex items-center gap-4">
                {{!-- social media icons --}}
                {{#social_accounts @site}}
                    <a href="{{href}}" target="_blank" title="Visit the {{name}} profile"
                        class="h-5 w-5 hover:opacity-80 transition-opacity items-center justify-center inline-flex"
                        rel="noopener" aria-label="Visit {{name}}'s {{type}} profile">
                         {{#> (concat "icons/" type)}}
                          {{name}}
                        {{/undefined}}
                    </a>
                {{/social_accounts}}
            </div>
        </div>
    </div>
</footer>
