<header x-data="{
    mobileMenu: false,
    dropdown: null
  }" @keydown.escape.window="
    mobileMenu = false;
    dropdown = null;
  " class="relative z-50 h-17.5 border-b border-zinc-800 bg-zinc-950">
  <div class="mx-auto flex items-center justify-between px-6 py-3 flex-row gap-3 w-full">

    <!-- Logo -->
    <a href="{{@site.url}}" class="flex items-center gap-3">
      {{#if @site.logo}}
      <img class="h-10 hidden xl:block object-cover" src="{{@site.logo}}" alt="{{@site.title}}" />
      {{else}}
      <div class="flex h-10 items-center justify-center">
        <span class="text-2xl font-bold text-white">{{@site.title}}</span>
      </div>
      {{/if}}
      {{#if @site.icon}}
      <img class="h-10 xl:hidden object-cover" src="{{@site.icon}}" alt="{{@site.title}}" />
      {{/if}}
    </a>


    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-5 lg:gap-10">
      {{navigation}}
    </nav>

    <div class="inline-flex items-center gap-4 sm:gap-6">
   
      {{!-- Search Button --}}
      <button data-ghost-search="true" id="search-toggle" aria-label="Toggle search"
        class="shrink-0 cursor-pointer h-4 w-4 duration-300 transition-opacity hover:opacity-80 items-center justify-center inline-flex">
        {{> "icons/search" name="search"  id="search-icon" aria-label="Search icon"}}
      </button>

      {{!-- social media icons --}}
      {{#social_accounts @site}}
      <a href="{{href}}" target="_blank" title="Visit the {{name}} profile"
        class="hidden h-4 w-4 hover:opacity-80 transition-opacity items-center justify-center lg:inline-flex"
        rel="noopener" aria-label="Visit {{name}}'s {{type}} profile">
          {{#> (concat "icons/" type)}}
          {{name}}
        {{/undefined}}
      </a>
      {{/social_accounts}}

      {{#if @member}}
      <div x-data="{ open: false }" class="relative">
        <button @click="open = !open" class="shrink-0 size-8 rounded-full overflow-hidden border border-zinc-700 hover:opacity-80 transition-opacity">
          {{#if @member.avatar_image}}
          <img src="{{@member.avatar_image}}" alt="{{@member.name}}" class="size-full object-cover" />
          {{else}}
          <div  style="background-color: {{@site.accent_color}}; color: {{contrast_text_color @site.accent_color}}" class="size-full flex items-center border rounded-full justify-center text-xs font-medium">
            {{#foreach (split @member.firstname separator="")}}
              {{#if @first}}
                {{this}}
              {{/if}}
            {{/foreach}}
          </div>
          {{/if}}
        </button>
        <div x-show="open" @click.outside="open = false" x-cloak
          class="absolute right-0 top-full mt-2 w-56 rounded-xl border border-zinc-800 bg-zinc-950 p-2 shadow-xl">
          <div class="px-3 py-2 border-b border-zinc-800 mb-1">
            <p class="text-sm font-medium text-white">{{@member.name}}</p>
            <p class="text-xs text-zinc-400">{{@member.email}}</p>
          </div>
          <a href="/#/portal/account/" class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-zinc-300 hover:bg-zinc-800 transition-colors">
            Account
          </a>
          <a href="javascript:" data-members-signout class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-zinc-300 hover:bg-zinc-800 transition-colors">
            Sign Out
          </a>
        </div>
      </div>
      {{/if}}

    <!-- Mobile Toggle -->
    <button type="button" class="rounded-lg p-2 block md:hidden hover:bg-zinc-900" @click="mobileMenu = !mobileMenu"
      aria-label="Toggle menu">
      <!-- Hamburger -->
      <svg x-show="!mobileMenu" x-transition class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>

      <!-- Close -->
      <svg x-show="mobileMenu" x-transition x-cloak class="h-6 w-6" fill="none" stroke="currentColor"
        viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>

      {{#unless @member}}
        {{#if @custom.show_sign_in}}
        <a href="/login" class="hidden md:block rounded-xl border border-zinc-700 px-4 py-2 text-zinc-200">
          Sign In
        </a>
        {{/if}}

      {{#if @custom.show_pro}}
      <a href="/signin" class="hidden md:block rounded-xl px-4 py-2 font-medium text-white"
        style="background-color: {{@site.accent_color}}; color: {{contrast_text_color @site.accent_color}}">
        Sign Up
      </a>
      {{/if}}
      {{/unless}}

    </div>
  </div>

  <!-- Mobile Navigation -->
  <div x-show="mobileMenu" x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2" x-transition:enter-end="opacity-100 translate-y-0"
    x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100 translate-y-0"
    x-transition:leave-end="opacity-0 -translate-y-2" x-cloak class="border-t border-zinc-800 bg-zinc-950">
    <nav class="flex flex-col my-6 items-center gap-3.5">
      {{navigation}}
    </nav>

    <div class="inline-flex mx-auto my-3 justify-center w-full items-center gap-6">

      {{!-- social media icons --}}
      {{#social_accounts @site}}
      <a href="{{href}}" target="_blank" title="Visit the {{name}} profile"
        class="h-4 w-4 duration-300 transition-opacity hover:opacity-80 items-center justify-center inline-flex"
        rel="noopener" aria-label="Visit {{name}}'s {{type}} profile">
           {{#> (concat "icons/" type)}}
           {{name}}
        {{/undefined}}      
      </a>
      {{/social_accounts}}

    </div>

    <div class="mt-4 flex flex-col gap-3 px-3">
      {{#unless @member}}
      {{#if @custom.show_pro}}
      <a href="/signin" class="rounded-xl shrink-0 px-4 py-3 text-center text-white"
        style="background-color: var(--ghost-accent-color)">
        Sign Up
      </a>
      {{/if}}

      {{#if @custom.show_sign_in}}
      <a href="/login" class="rounded-xl shrink-0 border border-zinc-700 px-4 py-3 text-center">
        Sign In
      </a>
      {{/if}}
      {{/unless}}
    </div>
  </div>
</header>