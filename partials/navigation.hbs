{{#if isSecondary}}
    <ul class="flex items-center gap-6 list-none p-0 m-0">
        {{#foreach navigation}}
            <li>
                <a href="{{url absolute="true"}}" class="text-sm text-muted-foreground hover:text-foreground transition-colors">{{label}}</a>
            </li>
        {{/foreach}}
    </ul>
{{else}}
    <ul class="flex items-center gap-1 list-none p-0 m-0">
        {{#foreach navigation}}
            <li>
                {{#link href=(url absolute="true") class="text-sm font-medium px-3 py-2 rounded-lg text-muted-foreground hover:text-foreground hover:bg-muted transition-colors" activeClass="text-foreground bg-muted"}} {{label}} {{/link}} 
            </li>
        {{/foreach}}
    </ul>
{{/if}}
