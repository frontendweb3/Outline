{{!< default}} 

{{> "hero"}}


{{> "tags"}}

    <section class="mx-auto max-w-324 px-4 md:px-12 lg:px-16 xl:px-20 2xl:px-0">

        <div class="grid w-full gap-10 grid-cols-1 md:grid-cols-2 lg:grid-cols-3">
            {{#foreach posts}}
            {{> "card"}}
            {{/foreach}}
        </div>


        {{#match @custom.pagination_style "simple"}}
            {{> "simple-pagination"}}
        {{else}}
            {{ "pagination"}}
        {{/match}}
</section>