{
  "name": "outline",
  "description": "Where content finds structure",
  "version": "0.0.0",
  "license": "MIT",
  "author": {
    "name": "Rajdeep Singh",
    "email": "officialrajdeepsingh@gmail.com"
  },
  "keywords": [
    "ghost-theme"
  ],
  "type": "module",
  "scripts": {
    "start ": "vite",
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "test": "pnpm dlx gscan@latest . --v6",
    "clean": "rm -rf ./assets/dist",
    "capture": "node scripts/screenshots/capture.js"
  },
  "config": {
    "posts_per_page": 10,
    "card_assets": true,
    "custom": {
      "pagination_style": {
        "type": "select",
        "options": [
          "basic",
          "simple"
        ],
        "default": "basic",
        "description": "Select pagination style for post listings"
      },
      "hero_title": {
        "type": "text",
        "default": "Tutorials",
        "group": "homepage",
        "description": "Custom title text for the hero section on the homepage (overrides site title)"
      },
      "card_style": {
        "type": "select",
        "options": [
          "featured",
          "simple"
        ],
        "default": "featured",
        "description": "Select the card style for post listings across index, tag, author, and related posts"
      },
      "show_sign_in": {
        "type": "boolean",
        "default": true,
        "description": "Show or hide the Sign In button in the header"
      },
      "show_pro": {
        "type": "boolean",
        "default": true,
        "description": "Show or hide the Go PRO button in the header"
      }
    }
  },
  "engines": {
    "ghost": ">=6.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "highlight.js": "^11.11.1",
    "highlightjs-copy": "^1.0.6",
    "playwright": "^1.61.0",
    "sharp": "^0.34.5",
    "svgo": "^4.0.0",
    "vite": "^7.3.1",
    "vite-plugin-image-optimizer": "^1.1.9",
    "vite-plugin-zip-pack": "^1.2.4"
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "alpinejs": "^3.15.8",
    "lucide": "^0.577.0",
    "shadcn": "^4.0.2",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0"
  }
}
